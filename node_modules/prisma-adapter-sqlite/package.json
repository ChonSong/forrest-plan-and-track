{
  "name": "prisma-adapter-sqlite",
  "version": "1.0.0",
  "description": "Prisma driver adapter for Node.js SQLite module",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Maxime-J/prisma-adapter-sqlite"
  },
  "scripts": {
    "dev": "DEV=true tsx helpers/build.ts",
    "build": "tsx helpers/build.ts"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "prisma",
    "adapter",
    "node",
    "sqlite",
    "node:sqlite"
  ],
  "author": "Maxime Jeunot <maxime.jeunot@gmail.com>",
  "license": "Apache-2.0",
  "sideEffects": false,
  "peerDependencies": {
    "@prisma/client": "^7.5.0"
  },
  "dependencies": {
    "@prisma/driver-adapter-utils": "7.5.0"
  },
  "devDependencies": {
    "@microsoft/api-extractor": "7.52.11",
    "@types/node": "25.4.0",
    "async-mutex": "0.5.0",
    "chokidar": "4.0.3",
    "esbuild": "0.25.5",
    "execa": "8.0.1",
    "fs-extra": "11.3.0",
    "globby": "11.1.0",
    "tsx": "4.19.3",
    "typescript": "5.4.5"
  },
  "packageManager": "pnpm@10.15.1"
}
